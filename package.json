{
  "name": "ledgerpro",
  "version": "1.0.0",
  "description": "نظام المحاسبة الاحترافي",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.ledgerpro.app",
    "productName": "LedgerPro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "manifest.json",
      "icon.png",
      "sw.js",
      "backend/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}